{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "rewrites": [
    {
      "source": "/dl/:path*",
      "destination": "https://sinaw-pharma-api.sinaw20003.workers.dev/:path*"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "geolocation=(), microphone=(), camera=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; img-src 'self' data:; connect-src 'self' https://sinaw-pharma-api.sinaw20003.workers.dev; frame-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; script-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/dl/:path*",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [ { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" } ]
    },
    {
      "source": "/sw.js",
      "headers": [ { "key": "Cache-Control", "value": "no-cache" } ]
    }
  ]
}
